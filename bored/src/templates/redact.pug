extends _layout.pug

block title
	| Redact | Bored

block main
	h1 Redact

	a(href=returnPath || (BASEURL + 'admin')) Go back.

	.messages
		+message(message)

	form(target=BASEURL + 'admin/redact' method="post")
		+csrf
		input(type="hidden" name="return" value=returnPath || path)
		input(type="hidden" name="mid" value=message.rowid)
		+field("Author")
			input(name="author" value=message.author required)
		+field("Message")
			textarea(name="body" required)= message.body
		button.outline Submit
